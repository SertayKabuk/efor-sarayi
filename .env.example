# OpenAI API key used by the backend
OPENAI_API_KEY=your_openai_api_key_here

# Azure OpenAI chat/completions endpoint and deployment
AZURE_ENDPOINT=https://your-resource.openai.azure.com/openai/v1/
AZURE_DEPLOYMENT_NAME=your_chat_deployment_name

# Azure OpenAI embeddings endpoint, deployment and key
AZURE_EMBEDDING_ENDPOINT=https://your-embedding-resource.openai.azure.com/openai/v1/
AZURE_EMBEDDING_DEPLOYMENT_NAME=your_embedding_deployment_name
AZURE_EMBEDDING_API_KEY=your_azure_embedding_api_key_here

# PostgreSQL connection settings
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_USER=your_postgres_user_here
POSTGRES_DB=your_postgres_database_here
DATABASE_URL=postgresql+asyncpg://your_postgres_user_here:your_postgres_password_here@postgres:5432/your_postgres_database_here

# Google OAuth client ID
GOOGLE_CLIENT_ID=your_google_client_id_here

# JWT signing secret (use a long random value)
JWT_SECRET=your_jwt_secret_here

# Directory where uploaded files will be stored
UPLOAD_DIR=uploads
UPLOADS_DIR=uploads

# Allowed email domain for Google SSO
ALLOWED_DOMAIN=example.com

# Development-only seed bypass settings
ALLOW_SEED_BYPASS_AUTH=false
SEED_AUTH_TOKEN=your_seed_auth_token_here